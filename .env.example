# Optional — Refactorika falls back to local JSON if unset or unreachable.
REDIS_URL=redis://localhost:6379/0
# Where the local-JSON fallback (edit log + analysis cache + graph + decisions) lives.
REFACTORIKA_STATE=.refactorika/state.json

# Required only for the --llm judgment passes (god-function decomposition, naming).
# Without it, the engine runs the deterministic plan and skips LLM steps.
ANTHROPIC_API_KEY=

# Optional embedding provider for semantic duplicate detection (the [semantic] extra).
# REFACTORIKA_EMBED=local|openai   (default: local sentence-transformers)
OPENAI_API_KEY=
