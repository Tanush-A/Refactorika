# --- State / memory (Redis primary, local-JSON fallback) -------------------------
# Redis Cloud or local. Refactorika falls back to local JSON if unset or unreachable.
REDIS_URL=redis://localhost:6379/0
# Where the local-JSON fallback (edit log, cache, graph, decisions) lives.
REFACTORIKA_STATE=.refactorika/state.json

# --- Generation provider (judgment: decomposition, NL->spec) ---------------------
# Provider: anthropic (default) | ollama. Embeddings are configured separately below,
# because Anthropic has no embeddings API.
REFACTORIKA_LLM_PROVIDER=anthropic
# REFACTORIKA_LLM_MODEL=claude-sonnet-4-6        # or e.g. llama3.1 for ollama
# REFACTORIKA_LLM_BASE_URL=http://localhost:11434 # ollama only
# API key for the generation provider; falls back to ANTHROPIC_API_KEY for anthropic.
# REFACTORIKA_LLM_API_KEY=
ANTHROPIC_API_KEY=

# --- Embedding provider (decision-memory vectors, duplicate detection) -----------
# Provider: local (default, all-MiniLM-L6-v2 via the [semantic] extra) | ollama.
REFACTORIKA_EMBED_PROVIDER=local
# REFACTORIKA_EMBED_MODEL=all-MiniLM-L6-v2        # or nomic-embed-text for ollama
OPENAI_API_KEY=
